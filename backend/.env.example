# Example backend environment variables
# Required: Firebase web API key (for REST sign-in)
FIREBASE_API_KEY=

# Optional: Firebase Admin service account credentials. Either provide JSON or a local path to a JSON file.
# For local dev you can set SERVICE_ACCOUNT_JSON='{ "type": ... }' (escape newlines) or point to a file path SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
SERVICE_ACCOUNT_JSON=
SERVICE_ACCOUNT_PATH=

# Required: a strong secret used to sign server JWTs. Do NOT commit real secrets to git.
JWT_SECRET=

# Optional: server port
PORT=4000

# Notes:
# - Copy this file to backend/.env and fill in values before running the backend in development.
# - Keep secrets out of version control.